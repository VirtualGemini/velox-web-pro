# 【通用】环境变量

#  版本号
VITE_VERSION = 3.0.2

# 端口号
VITE_PORT = 3000

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# 权限模式【 frontend 前端模式 / backend 后端模式 】
VITE_ACCESS_MODE = backend

# 跨域请求时是否携带 Cookie（开启前需确保后端支持）
VITE_WITH_CREDENTIALS = false

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏本地混淆值（仅客户端 UX 闸门、非安全边界；锁屏可被绕过，此值无机密意义，勿当真实密钥使用）
VITE_LOCK_ENCRYPT_KEY = velox-lock-ui-only
